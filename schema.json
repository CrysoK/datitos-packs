{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Datitos Packs Schema",
  "type": "object",
  "required": ["updated_at", "currency", "packs"],
  "properties": {
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mb", "days", "price"],
        "properties": {
          "mb": { "type": "number", "minimum": 0 },
          "days": { "type": "number", "minimum": 1 },
          "price": { "type": "number", "minimum": 0 },
          "comment": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
